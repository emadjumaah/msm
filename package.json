{
  "name": "msm-ai",
  "version": "1.4.0",
  "description": "MSM — Multi Small Models: An open standard for coordinated small model pipelines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "msm": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emadjumaah/msm.git"
  },
  "homepage": "https://github.com/emadjumaah/msm",
  "author": "emadjumaah",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx watch src/cli.ts",
    "demo": "tsx src/demo.ts",
    "demo:ollama": "tsx src/demo-ollama.ts",
    "server": "tsx src/server.ts",
    "server:ollama": "tsx src/server.ts --ollama",
    "benchmark": "tsx src/benchmark.ts",
    "benchmark:ollama": "tsx src/benchmark.ts --ollama",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "small-models",
    "pipeline",
    "msm",
    "multi-small-models",
    "arabic",
    "commerce"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  }
}